# ----------------------------------------------------------------------------
# Forge — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. Never commit `.env*`
# except this example file. All client-visible values MUST be prefixed with
# VITE_ — anything else is stripped out of the browser build by Vite.
# ----------------------------------------------------------------------------

# Supabase project — grab these from Project Settings → API
# The anon key is safe to expose publicly (it only grants row-level-security-
# scoped access), but treat it as a secret in development to avoid abuse.
VITE_SUPABASE_URL=https://<your-project-id>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Edge Function slug. Change this if you redeploy the function under a
# different name (historical value was `make-server-56c079d7`).
VITE_SUPABASE_FUNCTION_SLUG=make-server-56c079d7

# ----------------------------------------------------------------------------
# Server-only secrets (used by the Supabase Edge Function at deploy time,
# set with `supabase secrets set`). Not read by the browser build.
# ----------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=<server-only>
# GROK_API_KEY=<optional>
# OPENAI_API_KEY=<optional>
